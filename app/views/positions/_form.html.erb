<%= form_with(model: position) do |form| %>
  <% if position.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(position.errors.count, "error") %> prohibited this position from being saved:</h2>

      <ul>
        <% position.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <div >
      <%= form.label :latitude, style: "display: block" %>
      <%= form.text_field :latitude , data: { geolocation_target: "latitude" }%>
    </div>

    <div>
      <%= form.label :longitude, style: "display: block" %>
      <%= form.text_field :longitude, data: { geolocation_target: "longitude" }%>
    </div>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
